{
  "openapi": "3.0.0",
  "info": {
    "title": "VerdeAI v8.5 API Scaffold",
    "version": "8.5.0",
    "description": "Mock backend contract with safe AI render proxy scaffold. Paid render providers are disabled by default."
  },
  "paths": {
    "/api/health": {
      "get": {
        "summary": "Check backend health",
        "responses": {
          "200": {
            "description": "Backend is reachable"
          }
        }
      }
    },
    "/api/analyse": {
      "post": {
        "summary": "Analyse uploaded property context",
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "imageDataUrl": {
                    "type": "string"
                  },
                  "propertyType": {
                    "type": "string",
                    "description": "Includes v8.5 values such as needs-review and under-building."
                  },
                  "preference": {
                    "type": "string"
                  },
                  "constraint": {
                    "type": "string",
                    "description": "Main problem selected by the tester, e.g. shade-dark, access-awkward, privacy-gap, maintenance-drag, water-risk."
                  },
                  "budget": {
                    "type": "string"
                  },
                  "maintenance": {
                    "type": "string"
                  },
                  "postcode": {
                    "type": "string"
                  },
                  "note": {
                    "type": "string"
                  },
                  "starterCue": {
                    "type": "string",
                    "description": "Optional v8.5 starter clue such as shade, access, tired, utility, or edge."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Property DNA result"
          }
        }
      }
    },
    "/api/futures": {
      "post": {
        "summary": "Generate possible property futures",
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "propertyType": {
                    "type": "string"
                  },
                  "preference": {
                    "type": "string"
                  },
                  "constraint": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Future concept list"
          }
        }
      }
    },
    "/api/render": {
      "post": {
        "summary": "Prepare a mock render request or future provider render call",
        "responses": {
          "200": {
            "description": "Mock render result with provider, future, prompt, and estimated cost fields"
          }
        },
        "description": "v8.5 render scaffold. Real providers are not connected by default; this endpoint documents the future provider proxy contract.",
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "provider": {
                    "type": "string",
                    "enum": [
                      "none",
                      "replicate-flux",
                      "openai-image",
                      "stability-ai"
                    ]
                  },
                  "futureId": {
                    "type": "string"
                  },
                  "count": {
                    "type": "number"
                  },
                  "prompt": {
                    "type": "string"
                  },
                  "overlayLabels": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/report": {
      "post": {
        "summary": "Generate a report from project state",
        "responses": {
          "200": {
            "description": "Generated report"
          }
        }
      }
    },
    "/api/render/providers": {
      "get": {
        "summary": "List safe render provider status",
        "responses": {
          "200": {
            "description": "Provider readiness status"
          }
        }
      }
    },
    "/api/render/estimate": {
      "post": {
        "summary": "Estimate render cost before confirmation",
        "responses": {
          "200": {
            "description": "Cost estimate and safety status"
          }
        }
      }
    }
  }
}
