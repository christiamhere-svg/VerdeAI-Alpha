{
  "openapi": "3.0.0",
  "info": {
    "title": "VerdeAI v9.2 Secure Pilot API Scaffold",
    "version": "9.2.1",
    "description": "One-image-only secure pilot contract. Mock mode is active, the kill switch is on, provider calls are off, paid calls are locked, and no frontend secret is used."
  },
  "paths": {
    "/api/health": {
      "get": {
        "summary": "Check locked backend readiness",
        "responses": {
          "200": {
            "description": "Backend and approval-gate state"
          }
        }
      }
    },
    "/api/render/providers": {
      "get": {
        "summary": "List mock and prepared provider status",
        "responses": {
          "200": {
            "description": "Provider readiness without exposing secrets"
          }
        }
      }
    },
    "/api/render/estimate": {
      "post": {
        "summary": "Estimate exactly one concept render before confirmation",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OneRenderRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Prepared estimate or explicit lock state"
          },
          "400": {
            "description": "Invalid request; count must equal one"
          }
        }
      }
    },
    "/api/render": {
      "post": {
        "summary": "Run mock rehearsal or, only after owner activation, one provider image edit",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OneRenderRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Mock result or one AI concept render"
          },
          "400": {
            "description": "Consent, image, metadata, calibration or count validation failed"
          },
          "423": {
            "description": "Owner approval, kill switch, budget or tester gate blocked the call"
          },
          "504": {
            "description": "Provider timeout; return free calibrated-overlay fallback"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "OneRenderRequest": {
        "type": "object",
        "required": [
          "provider",
          "count",
          "futureId",
          "prompt",
          "confirmRender",
          "confirmPrivacy",
          "confirmImageUse",
          "confirmConceptOnly",
          "confirmCost"
        ],
        "properties": {
          "provider": {
            "type": "string",
            "enum": [
              "mock",
              "openai-gpt-image-2"
            ]
          },
          "count": {
            "type": "integer",
            "enum": [
              1
            ]
          },
          "futureId": {
            "type": "string"
          },
          "selectedFuture": {
            "type": "string"
          },
          "recommendedFuture": {
            "type": "string"
          },
          "propertySituation": {
            "type": "string"
          },
          "prompt": {
            "type": "string"
          },
          "imageDataUrl": {
            "type": "string",
            "description": "JPEG, PNG or WebP data URL resized and re-encoded before upload"
          },
          "imageBytes": {
            "type": "integer",
            "maximum": 2621440
          },
          "metadataStripped": {
            "type": "boolean",
            "enum": [
              true
            ]
          },
          "maxCostUsd": {
            "type": "number",
            "maximum": 0.15
          },
          "sessionId": {
            "type": "string"
          },
          "testerId": {
            "type": "string"
          },
          "confirmRender": {
            "type": "boolean"
          },
          "confirmPrivacy": {
            "type": "boolean"
          },
          "confirmImageUse": {
            "type": "boolean"
          },
          "confirmConceptOnly": {
            "type": "boolean"
          },
          "confirmCost": {
            "type": "boolean"
          },
          "calibration": {
            "type": "object",
            "required": [
              "usableGround",
              "protectedAccessRoute",
              "marker5"
            ],
            "properties": {
              "usableGround": {
                "type": "array",
                "items": {
                  "type": "object"
                }
              },
              "keepClear": {
                "type": "array",
                "items": {
                  "type": "object"
                }
              },
              "protectedAccessRoute": {
                "type": "array",
                "items": {
                  "type": "object"
                }
              },
              "opportunityPoint": {
                "type": "object"
              },
              "marker5": {
                "type": "object"
              }
            }
          }
        }
      }
    }
  }
}
