# VerdeAI v5.9 backend render proxy environment example
# Keep all provider keys server-side. Never paste real API keys into frontend code.

PORT=8080
VERDEAI_ENV=alpha
VERDEAI_REAL_RENDERING_ENABLED=false
VERDEAI_DEFAULT_IMAGE_PROVIDER=mock
VERDEAI_MAX_RENDER_COST_USD=0.15
VERDEAI_MAX_BATCH_COST_USD=0.75

# Provider keys - server only, optional, leave blank until paid rendering is intentionally connected.
REPLICATE_API_TOKEN=
OPENAI_API_KEY=
STABILITY_API_KEY=

# Optional provider model hints
REPLICATE_FLUX_MODEL=black-forest-labs/flux-dev
OPENAI_IMAGE_MODEL=gpt-image-1
STABILITY_MODEL=stable-image-core
