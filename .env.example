# VerdeAI v9.2.2 local Node reference backend.
# The production pilot uses cloudflare-worker/wrangler.jsonc and Worker secrets.
VERDEAI_REAL_RENDERING_ENABLED=false
VERDEAI_RENDER_KILL_SWITCH=true
VERDEAI_RENDER_TEST_MODE=true
VERDEAI_APPROVED_PROVIDER=openai-gpt-image-2
VERDEAI_APPROVED_BACKEND=cloudflare-worker
VERDEAI_RETENTION_POLICY=no-store
VERDEAI_PILOT_SPEND_CAP_USD=0
VERDEAI_INVITED_TESTER_LIMIT=0
VERDEAI_PER_SESSION_LIMIT=1
VERDEAI_PER_IP_DAILY_LIMIT=2
VERDEAI_MAX_COST_PER_RENDER_USD=0.15
VERDEAI_RENDER_MAX_IMAGE_BYTES=2621440
VERDEAI_RENDER_TIMEOUT_MS=120000
VERDEAI_ALLOWED_ORIGIN=https://verdeai-alpha.pages.dev
# Never commit real secret values:
# OPENAI_API_KEY=
# VERDEAI_RATE_LIMIT_SALT=
# PILOT_INVITE_CODE_HASHES=
